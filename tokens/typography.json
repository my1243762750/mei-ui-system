{
  "$schema": "version 1.0",
  "fontFamily": {
    "sans": {
      "web": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "flutter": "GoogleFonts.inter",
      "description": "Primary UI font"
    },
    "mono": {
      "web": "'JetBrains Mono', 'Fira Code', monospace",
      "flutter": "GoogleFonts.jetBrainsMono",
      "description": "Code and monospace"
    }
  },
  "size": {
    "xs":  { "value": 12, "unit": "px" },
    "sm":  { "value": 14, "unit": "px" },
    "base": { "value": 16, "unit": "px" },
    "lg":  { "value": 18, "unit": "px" },
    "xl":  { "value": 20, "unit": "px" },
    "2xl": { "value": 24, "unit": "px" },
    "3xl": { "value": 30, "unit": "px" },
    "4xl": { "value": 36, "unit": "px" },
    "5xl": { "value": 48, "unit": "px" },
    "6xl": { "value": 60, "unit": "px" }
  },
  "lineHeight": {
    "tight":  1.25,
    "normal": 1.5,
    "relaxed": 1.75
  },
  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "letterSpacing": {
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.04em"
  }
}
